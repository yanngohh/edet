{
  "name": "ui",
  "version": "0.2.1",
  "scripts": {
    "start": "vite --clearScreen false --port $UI_PORT",
    "build": "npm run check && npm run prepare && vite build",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "package": "npm run build && rimraf dist.zip && cd dist && bestzip ../dist.zip *",
    "prepare": "npm run smui-theme-light && npm run smui-theme-dark",
    "smui-theme-light": "smui-theme compile public/smui.css -i src/theme",
    "smui-theme-dark": "smui-theme compile public/smui-dark.css -i src/theme/dark"
  },
  "dependencies": {
    "@holo-host/identicon": "^0.1.0",
    "@holochain/client": "^0.20.0",
    "@msgpack/msgpack": "^2.8.0",
    "@smui/button": "^7.0.0",
    "@smui/circular-progress": "^7.0.0",
    "@smui/common": "^7.0.0",
    "@smui/dialog": "^7.0.0",
    "@smui/drawer": "^7.0.0",
    "@smui/fab": "^7.0.0",
    "@smui/icon-button": "^7.0.0",
    "@smui/list": "^7.0.0",
    "@smui/slider": "^7.0.0",
    "@smui/snackbar": "^7.0.0",
    "@smui/textfield": "^7.0.0",
    "@smui/top-app-bar": "^7.0.0",
    "html5-qrcode": "^2.3.8",
    "material-design-icons": "^3.0.1",
    "qrcode": "^1.5.4",
    "smui-theme": "^7.0.0",
    "svelte-i18n": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@sveltejs/vite-plugin-svelte": "^3.1",
    "@tsconfig/svelte": "^5.0.0",
    "@types/node": "^20.14.10",
    "@types/qrcode": "^1.5.6",
    "bestzip": "^2.2.0",
    "eslint": "^9.9.0",
    "eslint-plugin-svelte": "^2.43.0",
    "rimraf": "^5.0.7",
    "svelte": "^4.0.0",
    "svelte-check": "^4.0.4",
    "tslib": "^2.4.1",
    "typescript": "^5.5.0",
    "vite": "^5.0.0"
  },
  "type": "module"
}
